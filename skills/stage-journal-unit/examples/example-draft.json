        "decl": "fundamental_theorem",
        "sorry_free": true,
        "axiom_manifest": ["propext", "Classical.choice", "Quot.sound"],
        "base": { "kernel": "lean4@4.15.0", "axioms": ["propext", "Classical.choice", "Quot.sound"], "mathlib": "mathlib@<pin>", "ffi": [] },
        "closure": []
      },
      "witness": {
