      "ingredient": "formalization",
      "title": "Fundamental Theorem of Statistical Learning",
      "statement": {
        "text": "A concept class is PAC-learnable exactly when it has finite VC dimension, with finite compression, vanishing Rademacher complexity, and the Sauer-Shelah growth bound all equivalent.",
        "decl": "fundamental_theorem",
        "signature": "PACLearnable C ↔ FiniteCompression C ↔ RademacherVanishes C ↔ FiniteSampleGrowth C"
      },
      "proof": {
